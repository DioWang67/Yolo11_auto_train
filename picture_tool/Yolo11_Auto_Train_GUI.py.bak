        self.log_text = QTextEdit()
        self.log_text.setPlainText("ж≠°и?дљњзФ®?Це??Хз?еЈ•еЕЈпЉБ\nиЂЛйБЄ?Здїї?ЩдЄ¶йїЮж??Ле??Ји??В\n")
        self.log_text.setStyleSheet("""
            QTextEdit {
                background-color: #f8f9fa;
